{
  "manifest_version": 3,
  "name": "ResumeAI Summarizer Pro",
  "version": "1.0.0",
  "description": "Premium AI Web Summarizer to read long articles in seconds.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  }
}
